# Application environment
# Possible values: development, production
NODE_ENV=development

# Port on which the server will run locally.
# Render provides/uses its own PORT for web services.
PORT=5000

# Comma-separated frontend origins that can call this API with cookies.
# Local example:
CLIENT_ORIGIN=http://localhost:5173
# Production example:
# CLIENT_ORIGIN=https://your-github-username.github.io

# Secret used for signing sessions
# Use a strong random string of at least 32 characters in production.
SESSION_SECRET=your_session_secret

# Express session cookie name.
SESSION_COOKIE_NAME=splitapp.sid

# PostgreSQL connection URL.
# Local example:
# DATABASE_URL=postgres://username:password@localhost:5432/database_name
# Render production: use the Render Postgres internal database URL when possible.
DATABASE_URL=postgres://username:password@localhost:5432/database_name

# Database SSL mode.
# Local Postgres usually uses false. Production defaults to require if this is omitted.
DATABASE_SSL=false
