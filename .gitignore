# ==========================================
# Dependencies & Package Managers
# ==========================================
# Ignores all node_modules across the root and all subfolders
node_modules/
.pnpm-debug.log*

# ==========================================
# Build Outputs & Artifacts
# ==========================================
# Ignores production builds from Vite (frontend) or compiled backend code
dist/
build/
out/
.production/

# ==========================================
# Environment Secrets (CRITICAL)
# ==========================================
# Never commit credentials, API keys, or database URLs to GitHub
.env
.env.local
.env.*.local
*.env
auth.json

# ==========================================
# Operating System & IDE Trash
# ==========================================
# macOS system files
.DS_Store
Thumbs.db

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iws
*.iml

# VS Code configurations
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json

# ==========================================
# Logs and Diagnostics
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Local/Temporary Files
# ==========================================
.eslintcache
.stylelintcache
.turbo/
.cache/

.env.production